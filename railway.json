{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "go build -o build/glance .",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "runtime": "UNSPECIFIED",
    "numReplicas": 1,
    "startCommand": "go run .",
    "healthcheckPath": "/",
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
